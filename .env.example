# luna Brain — Environment Variables
# Copy this to .env.local and fill in real values:
#   cp .env.example .env.local

# Supabase (get from: supabase.com > Project > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Dashboard auth (choose any strong password)
DASHBOARD_PASSWORD=choose-something-strong

# Optional: Slack webhook for automated updates
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: Cron job secret for scheduled tasks
# CRON_SECRET=random-secret-string
